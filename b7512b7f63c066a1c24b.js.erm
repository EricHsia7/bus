{"'Arrays must have the same length'":"E0","`HTTP ${response.status}`":"E1","'No response body to stream'":"E2","'string notation required for auto precision.'":"E3","INPUT_ERROR":"E4","FINALIZE_ERROR":"E5","'Invalid mode: ' + mode":"E6","'Invalid version: ' + version":"E7","'Invalid mode'":"E8","'Param is not a string'":"E9","'Unknown mode: ' + string":"E10","'Invalid data'":"E11","'The amount of data is too big to be stored in a QR Code'":"E12","'\\n' +\n      'The chosen QR Code version cannot contain this amount of data.\\n' +\n      'Minimum version required to store current data is: ' + bestVersion + '.\\n'":"E13","'No input text'":"E14","'Encoder not initialized'":"E15","'\"' + data + '\"' +\n      ' cannot be encoded with mode ' + Mode.toString(mode) +\n      '.\\n Suggested mode is: ' + Mode.toString(bestMode)":"E16","'\"version\" cannot be null or undefined'":"E17","'\"version\" should be in range from 1 to 40'":"E18","'\"toSJISFunc\" is not a valid function.'":"E19","'Invalid QR Code version'":"E20","ed[0]":"E21","msg || ec[ind]":"E22","message.error":"E23","'Invalid JSON response from server'":"E24","'The provider is not valid.'":"E25","'store timed out'":"E26","msg":"E27","'BitMatrix size must be defined and greater than 0'":"E28","'Unknown EC Level: ' + string":"E29","'log(' + n + ')'":"E30","'Invalid SJIS character: ' + this.data[i] + '\\n' +\n        'Make sure your charset is UTF-8'":"E31","'bad maskPattern:' + maskPattern":"E32","\"Cannot find module '\"+o+\"'\"":"E33","'resolver must be a function'":"E34","'Cannot resolve promise with itself'":"E35","'must be an array'":"E36","\"Cannot call a class as a function\"":"E37","'Failed to get type for BinaryArray'":"E38","'Unkown type: ' + type":"E39","\"Can't call config() after localforage \" + 'has been used.'":"E40","'Database version must be a number.'":"E41","'Custom driver not compliant; see ' + 'https://mozilla.github.io/localForage/#definedriver'":"E42","'Method ' + methodName + ' is not implemented by the current driver'":"E43","'Driver not found.'":"E44","'No available storage method found.'":"E45"}