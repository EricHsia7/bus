{"'Arrays must have the same length'":"E0","`HTTP ${response.status}`":"E1","'No response body to stream'":"E2","'string notation required for auto precision.'":"E3","INPUT_ERROR":"E4","FINALIZE_ERROR":"E5","'Invalid mode: ' + mode":"E6","'Invalid version: ' + version":"E7","'Invalid mode'":"E8","'Param is not a string'":"E9","'Unknown mode: ' + string":"E10","'Invalid data'":"E11","'The amount of data is too big to be stored in a QR Code'":"E12","'\\n' +\n      'The chosen QR Code version cannot contain this amount of data.\\n' +\n      'Minimum version required to store current data is: ' + bestVersion + '.\\n'":"E13","'No input text'":"E14","'Encoder not initialized'":"E15","'\"' + data + '\"' +\n      ' cannot be encoded with mode ' + Mode.toString(mode) +\n      '.\\n Suggested mode is: ' + Mode.toString(bestMode)":"E16","'\"version\" cannot be null or undefined'":"E17","'\"version\" should be in range from 1 to 40'":"E18","'\"toSJISFunc\" is not a valid function.'":"E19","'Invalid QR Code version'":"E20","ed[0]":"E21","msg || ec[ind]":"E22","message.error":"E23","'Invalid JSON response from server'":"E24","'The provider is not valid.'":"E25","msg":"E26","'BitMatrix size must be defined and greater than 0'":"E27","'Unknown EC Level: ' + string":"E28","'log(' + n + ')'":"E29","'Invalid SJIS character: ' + this.data[i] + '\\n' +\n        'Make sure your charset is UTF-8'":"E30","'bad maskPattern:' + maskPattern":"E31"}